#!/usr/bin/env bash
# bstow - GNU Stow clone in pure Bash
# Usage: bstow [stow|unstow|restow] package1 package2 ...

set -euo pipefail

# Configuration
STOW_DIR="${STOW_DIR:-$PWD}"
TARGET_DIR="${TARGET_DIR:-$HOME}"
VERBOSE="${VERBOSE:-0}"
DRY_RUN="${DRY_RUN:-0}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging functions
log() {
    [[ $VERBOSE -eq 1 ]] && echo -e "${BLUE}[INFO]${NC} $*" >&2
}

success() {
    echo -e "${GREEN}[✓]${NC} $*" >&2
}

warn() {
    echo -e "${YELLOW}[!]${NC} $*" >&2
}

error() {
    echo -e "${RED}[✗]${NC} $*" >&2
}

# Get relative path from target to source
get_relative_path() {
    local source="$1"
    local target="$2"
    
    # Use Python if available for accurate relative paths
    if command -v python3 &>/dev/null; then
        python3 -c "import os; print(os.path.relpath('$source', os.path.dirname('$target')))"
    else
        # Fallback: simple relative path
        echo "$source"
    fi
}

# Create symlink
create_link() {
    local src="$1"
    local dest="$2"
    
    log "Creating link: $dest -> $src"
    
    if [[ $DRY_RUN -eq 1 ]]; then
        echo "[DRY-RUN] Would link: $dest -> $src"
        return 0
    fi
    
    # Create parent directory if needed
    local parent_dir
    parent_dir="$(dirname "$dest")"
    if [[ ! -d "$parent_dir" ]]; then
        log "Creating directory: $parent_dir"
        mkdir -p "$parent_dir"
    fi
    
    # Check if destination exists
    if [[ -e "$dest" || -L "$dest" ]]; then
        if [[ -L "$dest" ]]; then
            local current_target
            current_target="$(readlink "$dest")"
            if [[ "$current_target" == "$src" ]]; then
                log "Link already exists and is correct: $dest"
                return 0
            else
                warn "Link exists but points elsewhere: $dest -> $current_target"
                warn "Removing old link"
                rm "$dest"
            fi
        else
            error "File exists and is not a symlink: $dest"
            error "Please remove or backup manually"
            return 1
        fi
    fi
    
    # Create symlink
    ln -s "$src" "$dest"
    success "Linked: $dest -> $src"
}

# Remove symlink
remove_link() {
    local dest="$1"
    local expected_src="$2"
    
    if [[ ! -L "$dest" ]]; then
        log "Not a symlink, skipping: $dest"
        return 0
    fi
    
    local current_target
    current_target="$(readlink "$dest")"
    
    if [[ "$current_target" != "$expected_src" ]]; then
        warn "Link points elsewhere, skipping: $dest -> $current_target (expected: $expected_src)"
        return 0
    fi
    
    log "Removing link: $dest"
    
    if [[ $DRY_RUN -eq 1 ]]; then
        echo "[DRY-RUN] Would remove: $dest"
        return 0
    fi
    
    rm "$dest"
    success "Removed: $dest"
    
    # Remove empty parent directories
    local parent_dir
    parent_dir="$(dirname "$dest")"
    while [[ "$parent_dir" != "$TARGET_DIR" && "$parent_dir" != "/" ]]; do
        if rmdir "$parent_dir" 2>/dev/null; then
            log "Removed empty directory: $parent_dir"
            parent_dir="$(dirname "$parent_dir")"
        else
            break
        fi
    done
}

# Stow a package
stow_package() {
    local package="$1"
    local package_dir="$STOW_DIR/$package"
    
    if [[ ! -d "$package_dir" ]]; then
        error "Package not found: $package_dir"
        return 1
    fi
    
    echo "Stowing package: $package"
    
    # Find all files in package
    while IFS= read -r -d '' file; do
        # Get relative path from package dir
        local rel_path="${file#$package_dir/}"
        local src="$package_dir/$rel_path"
        local dest="$TARGET_DIR/$rel_path"
        
        # Skip if it's a directory (we only link files)
        [[ -d "$src" ]] && continue
        
        create_link "$src" "$dest" || return 1
    done < <(find "$package_dir" -type f -print0)
}

# Unstow a package
unstow_package() {
    local package="$1"
    local package_dir="$STOW_DIR/$package"
    
    if [[ ! -d "$package_dir" ]]; then
        error "Package not found: $package_dir"
        return 1
    fi
    
    echo "Unstowing package: $package"
    
    # Find all files in package
    while IFS= read -r -d '' file; do
        local rel_path="${file#$package_dir/}"
        local src="$package_dir/$rel_path"
        local dest="$TARGET_DIR/$rel_path"
        
        [[ -d "$src" ]] && continue
        
        remove_link "$dest" "$src"
    done < <(find "$package_dir" -type f -print0)
}

# Restow a package (unstow then stow)
restow_package() {
    local package="$1"
    unstow_package "$package"
    stow_package "$package"
}

# Show help
show_help() {
    cat <<EOF
Usage: bstow [OPTIONS] COMMAND PACKAGES...

A simple GNU Stow clone in pure Bash.

COMMANDS:
    stow        Create symlinks for packages
    unstow      Remove symlinks for packages
    restow      Unstow and then stow packages

OPTIONS:
    -d DIR      Set stow directory (default: current directory)
    -t DIR      Set target directory (default: \$HOME)
    -n          Dry run, don't make changes
    -v          Verbose output
    -h          Show this help

EXAMPLES:
    bstow stow vim nvim        # Stow vim and nvim packages
    bstow unstow bash          # Unstow bash package
    bstow -n -v stow tmux      # Dry run with verbose output
    bstow restow git           # Restow git package

ENVIRONMENT:
    STOW_DIR    Stow directory (default: \$PWD)
    TARGET_DIR  Target directory (default: \$HOME)
    VERBOSE     Enable verbose output (0 or 1)
    DRY_RUN     Enable dry run mode (0 or 1)

PACKAGE STRUCTURE:
    dotfiles/
    ├── bash/
    │   └── .bashrc
    ├── vim/
    │   └── .vimrc
    └── nvim/
        └── .config/
            └── nvim/
                └── init.lua

EOF
}

# Main
main() {
    # Parse options
    while getopts "d:t:nvh" opt; do
        case $opt in
            d) STOW_DIR="$OPTARG" ;;
            t) TARGET_DIR="$OPTARG" ;;
            n) DRY_RUN=1 ;;
            v) VERBOSE=1 ;;
            h) show_help; exit 0 ;;
            *) show_help; exit 1 ;;
        esac
    done
    shift $((OPTIND - 1))
    
    # Check arguments
    if [[ $# -lt 2 ]]; then
        error "Missing command or packages"
        show_help
        exit 1
    fi
    
    local command="$1"
    shift
    
    # Validate directories
    if [[ ! -d "$STOW_DIR" ]]; then
        error "Stow directory not found: $STOW_DIR"
        exit 1
    fi
    
    if [[ ! -d "$TARGET_DIR" ]]; then
        error "Target directory not found: $TARGET_DIR"
        exit 1
    fi
    
    # Convert to absolute paths
    STOW_DIR="$(cd "$STOW_DIR" && pwd)"
    TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"
    
    log "Stow directory: $STOW_DIR"
    log "Target directory: $TARGET_DIR"
    
    # Execute command for each package
    local exit_code=0
    for package in "$@"; do
        case $command in
            stow)
                stow_package "$package" || exit_code=1
                ;;
            unstow)
                unstow_package "$package" || exit_code=1
                ;;
            restow)
                restow_package "$package" || exit_code=1
                ;;
            *)
                error "Unknown command: $command"
                show_help
                exit 1
                ;;
        esac
    done
    
    exit $exit_code
}

# Run if executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
